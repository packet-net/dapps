@page
@model SettingsModel
@{
    ViewData["Title"] = $"DAPPS - settings ({Model.Options.Callsign})";
    ViewData["Active"] = "settings";
    ViewData["PageTitle"] = "Settings";
    ViewData["PageSubtitle"] = "Operator knobs. Most settings hot-reload within seconds; MQTT and UDP listener ports still need a daemon restart.";
    var nb = (Model.Options.NodeBearer ?? "agw").Trim().ToLowerInvariant();
    var ps = Model.Options.ProbeStrategy;
}

<style>
    /* Mask RHPv2 password without using <input type="password">, so
       Edge's password manager doesn't treat the (RhpUser, RhpPass)
       pair as credentials and paint a dark overlay over both fields. */
    input.masked {
        -webkit-text-security: disc;
        text-security: disc;
        font-family: var(--font-mono);
        letter-spacing: 0.18em;
    }

    /* Deployment-managed (env-set) fields: badge next to the label,
       control rendered read-only. See the env-managed script below. */
    .env-badge {
        display: inline-block; margin-left: 0.4rem;
        padding: 0.05rem 0.4rem; border-radius: 999px;
        font-size: 0.68rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.05em;
        background: color-mix(in srgb, var(--accent, #2563eb) 15%, transparent);
        color: var(--accent, #2563eb);
        cursor: help; vertical-align: middle;
    }
</style>

<form id="settings-form" onsubmit="dappsSaveConfig(event)" autocomplete="off" data-default-bearer-port="@Model.Options.DefaultBearerPort">
    <div class="panel">
        <h3>Identity &amp; packet-node bearer</h3>
        <p class="panel-sub">How DAPPS identifies itself and which packet node it rides on. Bearer port changes are picked up on the next forwarder tick (no restart).</p>
        <div class="field-grid">
            <div class="field"><label>Callsign</label><input name="Callsign" value="@Model.Options.Callsign" required />
                <span class="hint">includes optional SSID, e.g. <code>M0LTE-7</code></span></div>
            <div class="field"><label>Node host</label><input name="NodeHost" value="@Model.Options.NodeHost" required />
                <span class="hint">usually <code>localhost</code></span></div>
            <div class="field"><label>Node bearer</label>
                <select name="NodeBearer">
                    <option value="agw" selected="@(nb == "agw")">AGW (BPQ)</option>
                    <option value="rhpv2" selected="@(nb == "rhpv2")">RHPv2 (XRouter)</option>
                </select>
                <span class="hint">flip to switch the active inbound + outbound bearer</span>
            </div>
            <div class="field" data-bearer="agw"><label>AGW TCP port</label><input name="AgwPort" type="number" min="1" max="65535" value="@Model.Options.AgwPort" required />
                <span class="hint">BPQ's AGW listener (default <code>8000</code>)</span></div>
            <div class="field" data-bearer="rhpv2"><label>RHPv2 TCP port</label><input name="RhpPort" type="number" min="1" max="65535" value="@Model.Options.RhpPort" required />
                <span class="hint">XRouter's RHPv2 listener (default <code>9000</code>)</span></div>
            <div class="field" data-bearer="rhpv2"><label>RHPv2 user</label>
                <input name="RhpUser" type="text" value="@Model.Options.RhpUser"
                       autocomplete="off" data-form-type="other" data-1p-ignore="true" data-lpignore="true" />
                <span class="hint">blank if no auth</span></div>
            <div class="field" data-bearer="rhpv2"><label>RHPv2 password</label>
                <input name="RhpPass" type="text" value="@Model.Options.RhpPass"
                       autocomplete="off" data-form-type="other" data-1p-ignore="true" data-lpignore="true"
                       class="masked" />
                <span class="hint">stored on this node, not a sysop credential</span></div>
            <!-- DefaultBearerPort retired from the UI: with per-
                 neighbour radio-port assignment (now picked from a
                 BPQ-supplied dropdown in Topology -> Neighbours) the
                 global default added more confusion than value. The
                 model field stays in SystemOptions for back-compat
                 with stored configs and is preserved on save below. -->
        </div>
    </div>

    <div class="panel">
        <h3>App interface</h3>
        <p class="panel-sub">Local apps publish and subscribe through these. Restart required after changing ports.</p>
        <div class="field-grid">
            <div class="field"><label>MQTT broker port</label><input name="MqttPort" type="number" min="1" max="65535" value="@Model.Options.MqttPort" required /></div>
            <div class="field"><label>UDP listener port</label><input name="UdpListenPort" type="number" min="0" max="65535" value="@Model.Options.UdpListenPort" required />
                <span class="hint">0 = disabled. Stand-in for MeshCore-style datagram backhaul.</span></div>
            <label class="field-checkbox" style="grid-column: 1 / -1;">
                <input name="AuthRequired" type="checkbox" @(Model.Options.AuthRequired ? "checked" : "") />
                <span>Require per-app tokens for MQTT/REST<br/><span class="hint">leave off on a single-operator loopback node</span></span>
            </label>
        </div>
    </div>

    <div class="panel">
        <h3>MeshCore bearer</h3>
        <p class="panel-sub">LoRa radio bearer over a MeshCore private channel. Enable, port and region changes need a daemon restart; the rest hot-reload.</p>
        <div class="field-grid">
            <label class="field-checkbox" style="grid-column: 1 / -1;">
                <input name="MeshCoreEnabled" type="checkbox" @(Model.Options.MeshCoreEnabled ? "checked" : "") />
                <span>Enable the MeshCore bearer<br/><span class="hint">opens the serial radio and carries DAPPS traffic over a private channel</span></span>
            </label>
            <div class="field"><label>Serial port</label><input name="MeshCorePort" type="text" value="@Model.Options.MeshCorePort" /><span class="hint">e.g. /dev/ttyUSB0</span></div>
            <div class="field"><label>Region preset</label>
                <select name="MeshCoreRegion">
                    <option value="uk-narrow" selected="@(Model.Options.MeshCoreRegion == "uk-narrow")">UK 868 narrow — 869.618 / SF8 / CR8</option>
                    <option value="uk-test" selected="@(Model.Options.MeshCoreRegion == "uk-test")">UK test — 868.4 (isolated bench)</option>
                    <option value="eu-legacy" selected="@(Model.Options.MeshCoreRegion == "eu-legacy")">EU legacy wide — 869.525 / SF11</option>
                </select>
            </div>
            <div class="field"><label>TX power (dBm)</label><input name="MeshCoreTxPowerDbm" type="number" min="0" max="30" value="@Model.Options.MeshCoreTxPowerDbm" /><span class="hint">capped by the region's max</span></div>
            <div class="field"><label>Node name</label><input name="MeshCoreNodeName" type="text" value="@Model.Options.MeshCoreNodeName" /></div>
            <div class="field"><label>Channel slot</label><input name="MeshCoreChannelIndex" type="number" min="0" max="255" value="@Model.Options.MeshCoreChannelIndex" /><span class="hint">0 = public; 1+ = private</span></div>
            <div class="field"><label>Channel name</label><input name="MeshCoreChannelName" type="text" value="@Model.Options.MeshCoreChannelName" /></div>
            <div class="field"><label>Channel PSK</label><input name="MeshCoreChannelPsk" type="text" value="@Model.Options.MeshCoreChannelPsk" class="masked" /><span class="hint">32-char hex (16 bytes) or a passphrase</span></div>
            <div class="field"><label>Airtime budget (s/h)</label><input name="MeshCoreAirtimeBudgetSecondsPerHour" type="number" min="0" max="3600" step="1" value="@Model.Options.MeshCoreAirtimeBudgetSecondsPerHour" /><span class="hint">good-citizen duty cap</span></div>
            <div class="field"><label>Congestion backoff</label><input name="MeshCoreCongestionBackoffFraction" type="number" min="0" max="1" step="0.05" value="@Model.Options.MeshCoreCongestionBackoffFraction" /><span class="hint">back off at occupancy ≥ this (0 = off)</span></div>
            <div class="field"><label>LBT guard (ms)</label><input name="MeshCoreLbtGuardMs" type="number" min="0" max="10000" value="@Model.Options.MeshCoreLbtGuardMs" /></div>
            <label class="field-checkbox"><input name="MeshCoreCompress" type="checkbox" @(Model.Options.MeshCoreCompress ? "checked" : "") /><span>Compress payloads (zstd + dictionary)</span></label>
            <label class="field-checkbox"><input name="MeshCoreReliableDelivery" type="checkbox" @(Model.Options.MeshCoreReliableDelivery ? "checked" : "") /><span>End-to-end reliability (ACK + resend)</span></label>
        </div>
        <div class="panel-sub" style="margin-top:.75rem; display:flex; align-items:center; gap:.5rem;">
            <span>Status: <span id="mc-status">…</span></span>
            <button type="button" id="mc-reset" class="btn-secondary" style="margin-left:auto;">Reset radio</button>
        </div>
    </div>

    <div class="panel">
        <h3>Discovery &amp; airtime</h3>
        <p class="panel-sub">Total trailing-hour airtime cap shared by every discovery transmission (beacons, solicits, probes). Per-channel caps live in Topology.</p>
        <div class="field-grid">
            <div class="field"><label>Discovery airtime budget (s/h)</label>
                <input name="DiscoveryAirtimeBudgetSecondsPerHour" type="number" min="0" max="3600" value="@Model.Options.DiscoveryAirtimeBudgetSecondsPerHour" required />
                <span class="hint">0 = unlimited</span></div>
        </div>
    </div>

    <div class="panel">
        <h3>Probing &amp; routing</h3>
        <p class="panel-sub">B6.1 connected-mode probe + B7 strategy choice.</p>
        <div class="field-grid">
            <label class="field-checkbox"><input name="ProbingEnabled" type="checkbox" @(Model.Options.ProbingEnabled ? "checked" : "") />
                <span>Probe known peers on a slow cadence</span></label>
            <div class="field"><label>Probe interval (hours)</label><input name="ProbeIntervalHours" type="number" min="1" max="168" value="@Model.Options.ProbeIntervalHours" required /></div>
            <div class="field"><label>Strategy</label>
                <select name="ProbeStrategy">
                    <option value="FixedInterval" selected="@(ps == ProbeStrategy.FixedInterval)">Fixed interval</option>
                    <option value="Overnight" selected="@(ps == ProbeStrategy.Overnight)">Overnight</option>
                    <option value="WhenQuiet" selected="@(ps == ProbeStrategy.WhenQuiet)">When forwarder is quiet</option>
                </select>
            </div>
            <div class="field"><label>Overnight start hour</label><input name="ProbeOvernightStartHour" type="number" min="0" max="23" value="@Model.Options.ProbeOvernightStartHour" required /><span class="hint">local time</span></div>
            <div class="field"><label>Overnight end hour</label><input name="ProbeOvernightEndHour" type="number" min="0" max="23" value="@Model.Options.ProbeOvernightEndHour" required /></div>
            <div class="field"><label>Quiet window (s)</label><input name="ProbeQuietWindowSeconds" type="number" min="1" max="86400" value="@Model.Options.ProbeQuietWindowSeconds" required /></div>
            <label class="field-checkbox"><input name="AutoDiscoverViaNodeCall" type="checkbox" @(Model.Options.AutoDiscoverViaNodeCall ? "checked" : "") />
                <span>Auto-seed node-prompt probe candidates from inbound AGW beacons<br/><span class="hint">B6.1 phase 2b</span></span></label>
            <div class="field"><label>Node-prompt application command</label><input name="NodePromptApplicationCommand" type="text" value="@Model.Options.NodePromptApplicationCommand" /></div>
        </div>
    </div>

    <div class="panel">
        <h3>Polling</h3>
        <p class="panel-sub">F3 mail-pull. Opportunistic = drain on every push session; scheduled = walk neighbours on a cadence.</p>
        <div class="field-grid">
            <label class="field-checkbox"><input name="OpportunisticPollEnabled" type="checkbox" @(Model.Options.OpportunisticPollEnabled ? "checked" : "") />
                <span>Drain peers' mail at the end of every push session (F3a)</span></label>
            <label class="field-checkbox"><input name="ScheduledPollEnabled" type="checkbox" @(Model.Options.ScheduledPollEnabled ? "checked" : "") />
                <span>Schedule periodic mail polls (F3b)</span></label>
            <div class="field"><label>Poll interval (hours)</label><input name="PollIntervalHours" type="number" min="1" max="168" value="@Model.Options.PollIntervalHours" required /></div>
        </div>
    </div>

    <div class="panel">
        <h3>Heartbeat</h3>
        <p class="panel-sub">Periodic operational snapshot publish on <code>dapps/metrics/heartbeat</code>. Same JSON shape as <code>/Operational</code>.</p>
        <div class="field-grid">
            <label class="field-checkbox"><input name="HeartbeatEnabled" type="checkbox" @(Model.Options.HeartbeatEnabled ? "checked" : "") />
                <span>Publish heartbeat to MQTT</span></label>
            <div class="field"><label>Heartbeat interval (s)</label><input name="HeartbeatIntervalSeconds" type="number" min="10" max="3600" value="@Model.Options.HeartbeatIntervalSeconds" required /></div>
        </div>
    </div>

    <div class="panel">
        <h3>Updates</h3>
        <div class="field-grid">
            <label class="field-checkbox"><input name="UpdateCheckEnabled" type="checkbox" @(Model.Options.UpdateCheckEnabled ? "checked" : "") />
                <span>Auto-check GitHub for new releases<br/><span class="hint">background poll runs ~once an hour. Use the button below for an immediate poll.</span></span></label>
            <div class="field" style="grid-column: 1 / -1; align-items: flex-start;">
                <button type="button" class="btn ghost sm" id="check-updates-btn" style="margin-top: 0.4rem;">Check for updates now</button>
                <span class="hint" id="check-updates-status" style="margin-top: 0.5rem; min-height: 1em;"></span>
            </div>
        </div>
    </div>

    <div style="display: flex; justify-content: flex-end; gap: 0.5rem; margin: 1rem 0 1.5rem;">
        <button class="btn ghost" type="button" onclick="location.reload()">Discard</button>
        <button class="btn" type="submit">Save</button>
    </div>
</form>

<div class="panel">
    <h3>Rotate admin password</h3>
    <p class="panel-sub">Existing sessions stay valid until logout or 90-day expiry. Only future logins use the new password.</p>
    <form class="row-form" onsubmit="dappsRotatePassword(event)">
        <div class="field" style="grid-column: 1 / -1;"><label>New password</label>
            <input name="password" type="password" required minlength="8" autocomplete="new-password" />
        </div>
        <button class="btn" type="submit">Set password</button>
    </form>
</div>

<script>
async function dappsPostJson(url, body, method) {
    const res = await fetch(url, {
        method: method || 'POST',
        headers: { 'content-type': 'application/json' },
        body: body == null ? null : JSON.stringify(body),
    });
    if (!res.ok && res.status !== 204) {
        const text = await res.text();
        alert(`Request failed (${res.status}): ${text}`);
        return false;
    }
    return true;
}
async function dappsSaveConfig(ev) {
    ev.preventDefault();
    const f = ev.target;
    const body = {
        Callsign: f.Callsign.value,
        NodeHost: f.NodeHost.value,
        NodeBearer: f.NodeBearer.value,
        AgwPort: parseInt(f.AgwPort.value, 10),
        RhpPort: parseInt(f.RhpPort.value, 10),
        RhpUser: f.RhpUser.value,
        RhpPass: f.RhpPass.value,
        // DefaultBearerPort is no longer exposed on this form (Topology
        // -> Neighbours has a per-row port picker that supersedes it).
        // Send the existing persisted value back so we don't zero it
        // out on save - rendered server-side into the form's data
        // attribute on first paint.
        DefaultBearerPort: parseInt(f.dataset.defaultBearerPort ?? '0', 10),
        MqttPort: parseInt(f.MqttPort.value, 10),
        UdpListenPort: parseInt(f.UdpListenPort.value, 10),
        AuthRequired: f.AuthRequired.checked,
        UpdateCheckEnabled: f.UpdateCheckEnabled.checked,
        ProbingEnabled: f.ProbingEnabled.checked,
        ProbeIntervalHours: parseInt(f.ProbeIntervalHours.value, 10),
        ProbeStrategy: f.ProbeStrategy.value,
        ProbeOvernightStartHour: parseInt(f.ProbeOvernightStartHour.value, 10),
        ProbeOvernightEndHour: parseInt(f.ProbeOvernightEndHour.value, 10),
        ProbeQuietWindowSeconds: parseInt(f.ProbeQuietWindowSeconds.value, 10),
        OpportunisticPollEnabled: f.OpportunisticPollEnabled.checked,
        ScheduledPollEnabled: f.ScheduledPollEnabled.checked,
        PollIntervalHours: parseInt(f.PollIntervalHours.value, 10),
        DiscoveryAirtimeBudgetSecondsPerHour: parseInt(f.DiscoveryAirtimeBudgetSecondsPerHour.value, 10),
        HeartbeatEnabled: f.HeartbeatEnabled.checked,
        HeartbeatIntervalSeconds: parseInt(f.HeartbeatIntervalSeconds.value, 10),
        AutoDiscoverViaNodeCall: f.AutoDiscoverViaNodeCall.checked,
        NodePromptApplicationCommand: f.NodePromptApplicationCommand.value,
        MeshCoreEnabled: f.MeshCoreEnabled.checked,
        MeshCorePort: f.MeshCorePort.value,
        MeshCoreRegion: f.MeshCoreRegion.value,
        MeshCoreTxPowerDbm: parseInt(f.MeshCoreTxPowerDbm.value, 10),
        MeshCoreChannelIndex: parseInt(f.MeshCoreChannelIndex.value, 10),
        MeshCoreChannelName: f.MeshCoreChannelName.value,
        MeshCoreChannelPsk: f.MeshCoreChannelPsk.value,
        MeshCoreNodeName: f.MeshCoreNodeName.value,
        MeshCoreAirtimeBudgetSecondsPerHour: parseFloat(f.MeshCoreAirtimeBudgetSecondsPerHour.value),
        MeshCoreCompress: f.MeshCoreCompress.checked,
        MeshCoreCongestionBackoffFraction: parseFloat(f.MeshCoreCongestionBackoffFraction.value),
        MeshCoreLbtGuardMs: parseInt(f.MeshCoreLbtGuardMs.value, 10),
        MeshCoreReliableDelivery: f.MeshCoreReliableDelivery.checked,
    };
    if (await dappsPostJson('@Url.Content("~/Config")', body)) {
        const head = document.querySelector('.page-head');
        if (head) {
            const banner = document.createElement('div');
            banner.className = 'ok-banner';
            banner.textContent = 'Settings saved.';
            head.parentNode.insertBefore(banner, head.nextSibling);
            setTimeout(() => banner.remove(), 3000);
        }
    }
}
async function dappsRotatePassword(ev) {
    ev.preventDefault();
    const pwd = ev.target.password.value;
    if (await dappsPostJson('@Url.Content("~/Config/admin-password")', { password: pwd })) {
        ev.target.reset();
        alert('Password updated.');
    }
}

// --- Deployment-managed (env-set) fields ---
// Under DAPPS_ENV_MANAGED=true (the pdn supervised-app mode), any
// option whose DAPPS_* env var is set on the daemon's environment is
// re-applied from the environment at EVERY start, so a dashboard edit
// would be silently overridden on the next restart. Badge those
// fields and make them read-only so the operator isn't invited to
// fight the deployment. In the standalone default mode the list is
// always empty - env vars only seed first-start values there.
// The form still serialises their values on save (the JS reads .value
// // .checked directly, which works on readonly/disabled controls),
// so saving unrelated fields keeps env-managed ones intact.
(function () {
    const managed = @Json.Serialize(Model.EnvManaged.Select(f => new { key = f.Key, env = f.Env }));
    const form = document.getElementById('settings-form');
    if (!form) return;
    for (const m of managed) {
        const el = form.querySelector(`[name='${m.key}']`);
        if (!el) continue; // option without a form field (e.g. Ssid, DefaultBearerPort)
        if (el.tagName === 'SELECT' || el.type === 'checkbox') el.disabled = true;
        else el.readOnly = true;
        const badge = document.createElement('span');
        badge.className = 'env-badge';
        badge.textContent = 'managed by environment';
        badge.title = `Set from ${m.env} at every start — dashboard edits will be overridden while the variable remains set.`;
        const holder = el.closest('.field')?.querySelector('label')
            ?? el.closest('.field-checkbox')?.querySelector('span');
        holder?.appendChild(badge);
    }
})();

// --- Bearer-conditional fields ---
// AGW vs RHPv2 are mutually exclusive at runtime; showing all four
// fields at once is noisy and invites the operator to "fix" the
// inactive bearer's port without realising it does nothing. Hide the
// inactive bearer's fields while keeping their values intact - the
// form still serialises both, so flipping back later doesn't lose the
// previous bearer's settings.
(function () {
    const select = document.querySelector("select[name='NodeBearer']");
    const fields = document.querySelectorAll('[data-bearer]');
    function apply() {
        const active = (select?.value || 'agw').toLowerCase();
        for (const el of fields) {
            el.style.display = el.dataset.bearer === active ? '' : 'none';
        }
    }
    if (select) {
        select.addEventListener('change', apply);
        apply();
    }
})();

// --- Check for updates ---
// POST /Update/check makes the daemon hit GitHub once and returns the
// fresh status. Surface the outcome in plain English so the operator
// knows whether they're up to date without having to look elsewhere.
(function () {
    const btn = document.getElementById('check-updates-btn');
    const status = document.getElementById('check-updates-status');
    if (!btn || !status) return;
    btn.addEventListener('click', async () => {
        btn.disabled = true;
        status.textContent = 'checking GitHub...';
        try {
            const res = await fetch('@Url.Content("~/Update/check")', { method: 'POST' });
            if (!res.ok) {
                status.textContent = `check failed: HTTP ${res.status}`;
                return;
            }
            const j = await res.json();
            if (j.isDevBuild) {
                status.textContent = `running dev build ${j.current} - no upstream comparison`;
            } else if (j.isAvailable && j.latest) {
                status.textContent = `update available: v${j.current} -> v${j.latest}. Apply from the Overview hero or the topbar build chip.`;
            } else {
                status.textContent = `up to date - v${j.current}`;
            }
            // Nudge the topbar build chip to repaint immediately rather
            // than wait up to 5 s for the next /Operational poll.
            await window.dappsRefreshSnap?.();
        } catch (e) {
            status.textContent = `check failed: ${e.message ?? e}`;
        } finally {
            btn.disabled = false;
        }
    });
})();

// MeshCore bearer status + device-control reset (#159).
(function () {
    const statusEl = document.getElementById('mc-status');
    const resetBtn = document.getElementById('mc-reset');
    if (!statusEl) return;
    async function refresh() {
        try {
            const r = await fetch('@Url.Content("~/MeshCore/status")');
            if (!r.ok) { statusEl.textContent = 'unavailable'; return; }
            const s = await r.json();
            if (!s.enabled) { statusEl.textContent = 'disabled'; if (resetBtn) resetBtn.disabled = true; return; }
            if (resetBtn) resetBtn.disabled = false;
            const f = s.freqMhz != null ? s.freqMhz.toFixed(3) + 'MHz' : '?';
            const exp = s.reliableExpired ? ' / ' + s.reliableExpired + '✗' : '';
            statusEl.textContent = `${s.linkState} · ${f} SF${s.sf ?? '?'} CR${s.cr ?? '?'} · occ ${(s.occupancy * 100).toFixed(0)}% · rx ${s.delivered} · reliable ${s.reliableConfirmed}✓/${s.reliablePending}⋯${exp} · resets ${s.resets}`;
        } catch { statusEl.textContent = 'unavailable'; }
    }
    if (resetBtn) resetBtn.addEventListener('click', async () => {
        resetBtn.disabled = true;
        statusEl.textContent = 'resetting…';
        try { await fetch('@Url.Content("~/MeshCore/reset")', { method: 'POST' }); } catch { }
        setTimeout(refresh, 5000);
    });
    refresh();
    setInterval(refresh, 5000);
})();
</script>
